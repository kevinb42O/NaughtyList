VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
VITE_VAPID_PUBLIC_KEY=your-web-push-public-key
VITE_GIPHY_API_KEY=your-giphy-api-key
VITE_TENOR_API_KEY=your-tenor-api-key

# Supabase Edge Function secrets for Cloudflare R2 image uploads
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=naughtylist-media
R2_PUBLIC_URL=https://your-public-r2-domain.example.com
# R2_ENDPOINT is optional when R2_ACCOUNT_ID is set
# R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
